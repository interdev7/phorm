#.vscode/

# Flutter/Dart/Pub related
**/coverage/
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
**/.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/.cxx
/android/app/profile
/android/app/release
/ios/Podfile.lock
/android/app/google-services.json

# Generated files
*.g.dart
*.sql.g.dart
*.fn.g.dart

# fvm
.fvm/

# Melos-managed local path overrides (regenerated by `melos bootstrap`)
pubspec_overrides.yaml

# VS Code extension working files
.vscode/flutter-translator/

# MkDocs build output
site/

# Phorm Studio DevTools panel: the compiled web build MUST ship inside the
# phorm_devtools pub package (the panel sources live in a private repo).
!packages/phorm_devtools/extension/devtools/build/
!packages/phorm_devtools/extension/devtools/build/**
